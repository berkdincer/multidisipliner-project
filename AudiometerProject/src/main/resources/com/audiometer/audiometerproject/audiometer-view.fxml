<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.audiometer.audiometerproject.ui.MainController"
            prefWidth="1050" prefHeight="720"
            styleClass="root">

    <!-- ========== TOP: Header ========== -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header-bar">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Label text="Audiometer Test System" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Ready" styleClass="header-status"/>
        </HBox>
    </top>

    <!-- ========== CENTER: Audiogram ========== -->
    <center>
        <AnchorPane styleClass="audiogram-panel" BorderPane.alignment="CENTER">
            <BorderPane.margin><Insets top="12" right="8" bottom="12" left="16"/></BorderPane.margin>
            <Canvas fx:id="audiogramCanvas" width="640" height="620"
                    AnchorPane.topAnchor="5" AnchorPane.leftAnchor="5"
                    AnchorPane.rightAnchor="5" AnchorPane.bottomAnchor="5"/>
        </AnchorPane>
    </center>

    <!-- ========== RIGHT: Controls ========== -->
    <right>
        <VBox prefWidth="310" spacing="0" alignment="TOP_CENTER" styleClass="control-panel">
            <BorderPane.margin><Insets top="12" right="16" bottom="12" left="8"/></BorderPane.margin>

            <!-- EAR SELECTION -->
            <VBox styleClass="control-section" spacing="10" alignment="CENTER">
                <Label text="EAR SELECTION" styleClass="section-label"/>
                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="rightEarButton" text="RIGHT (O)" onAction="#handleRightEar"
                            prefWidth="130" prefHeight="42" styleClass="right-ear-active"/>
                    <Button fx:id="leftEarButton" text="LEFT (X)" onAction="#handleLeftEar"
                            prefWidth="130" prefHeight="42" styleClass="left-ear-inactive"/>
                </HBox>
            </VBox>

            <!-- FREQUENCY & VOLUME -->
            <VBox styleClass="control-section" spacing="12" alignment="CENTER">
                <HBox spacing="14" alignment="CENTER">
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="FREQUENCY (Hz)" styleClass="section-label"/>
                        <ComboBox fx:id="frequencyCombo" prefWidth="130" prefHeight="40"
                                  style="-fx-font-size: 14px;"/>
                    </VBox>
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="VOLUME (dB HL)" styleClass="section-label"/>
                        <Spinner fx:id="dbSpinner" prefWidth="130" prefHeight="40"
                                 style="-fx-font-size: 14px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- AUTO TEST ALGORITHM -->
            <VBox styleClass="control-section" spacing="10" alignment="CENTER" style="-fx-background-color: #f8fafc;">
                <Label text="AUTO TEST (HUGHSON-WESTLAKE)" styleClass="section-label"/>
                <Button fx:id="startAutoTestButton" text="▶  Start Auto Test" onAction="#handleStartAutoTest"
                        prefHeight="40" maxWidth="1.7976931348623157E308"
                        styleClass="auto-test-btn"/>
                <Label fx:id="algoStateLabel" text="State: IDLE" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            </VBox>

            <!-- ACTION BUTTONS -->
            <VBox styleClass="control-section" spacing="10" alignment="CENTER">
                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="playSoundButton" text="Play Tone" onAction="#handlePlaySound"
                            prefHeight="48" prefWidth="130"
                            styleClass="play-btn"/>
                    <Button fx:id="noResponseButton" text="No Response" onAction="#handleNoResponse"
                            prefHeight="48" prefWidth="130"
                            styleClass="no-response-btn"/>
                </HBox>

                <Button fx:id="heardButton" text="✔  Heard" onAction="#handleHeard"
                        prefHeight="58" maxWidth="1.7976931348623157E308"
                        styleClass="heard-btn"/>

                <Separator style="-fx-padding: 6 0 6 0;"/>

                <Button fx:id="clearButton" text="✖  Clear Audiogram" onAction="#handleClear"
                        prefHeight="38" maxWidth="1.7976931348623157E308"
                        styleClass="clear-btn"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </right>
</BorderPane>